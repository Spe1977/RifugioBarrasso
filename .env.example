# Rifugio Barrasso – Variabili d'ambiente
# Copiare in .env e compilare con i valori reali.
# Le variabili PUBLIC_ sono visibili nel frontend: NON inserire segreti.

# Google Apps Script – endpoint deploy Web App
PUBLIC_BOOKING_ENDPOINT=

# Google Calendar – URL embed iframe (versione "solo libero/occupato")
PUBLIC_GOOGLE_CALENDAR_EMBED_URL=

# Tally – ID del form dediche (es. "wA1b2C")
PUBLIC_TALLY_FORM_ID=

# Endpoint per le dediche (Apps Script)
PUBLIC_DEDICHE_ENDPOINT=
