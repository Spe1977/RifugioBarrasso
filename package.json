{
  "name": "rifugio-barrasso",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev --host 0.0.0.0",
    "check": "ASTRO_TELEMETRY_DISABLED=1 astro check",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro check && ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview --host 0.0.0.0",
    "preview:cloudflare": "npm run build && npx wrangler pages dev dist --compatibility-date=2026-05-07",
    "deploy:cloudflare": "npm run build && npx wrangler pages deploy dist --project-name rifugio-barrasso",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:server": "PLAYWRIGHT_START_SERVER=1 playwright test",
    "test:lighthouse": "lhci autorun",
    "test:all": "npm run format:check && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.3.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.26.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.17",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.26.0",
    "eslint-plugin-astro": "^1.3.1",
    "globals": "^16.1.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0",
    "vitest": "^3.1.3"
  }
}
