---
type Props = {
  eyebrow?: string;
  title: string;
  lead?: string;
};

const { eyebrow, title, lead } = Astro.props;
---

<div class="mb-10 max-w-3xl">
  {
    eyebrow && (
      <p class="mb-3 text-sm font-bold uppercase tracking-[0.24em] text-majella-red">
        {eyebrow}
      </p>
    )
  }
  <h2
    class="font-display text-3xl font-black uppercase leading-tight text-majella-green md:text-4xl"
  >
    {title}
  </h2>
  {lead && <p class="mt-4 text-lg leading-8 text-gray-600">{lead}</p>}
</div>
