---
import { footerLinks, navigation, site } from "@data/site";

const year = new Date().getFullYear();
---

<footer class="terrain-surface text-white">
  <div
    class="mx-auto grid max-w-7xl gap-10 px-4 py-12 sm:px-6 lg:grid-cols-[1.4fr_1fr_1fr] lg:px-8"
  >
    <div>
      <picture>
        <source srcset="/assets/brand/logo2-96.webp" type="image/webp" />
        <img
          src="/assets/brand/logo2-96.png"
          alt=""
          class="mb-5 h-20 w-20 bg-white/95 object-contain p-2"
          loading="lazy"
          width="80"
          height="80"
        />
      </picture>
      <p class="font-display text-2xl font-black uppercase tracking-wide">
        {site.name}
      </p>
      <p class="mt-3 max-w-md text-sm leading-6 text-white/78">
        {site.location}, {site.subtitle}. Gestione {site.manager}.
      </p>
    </div>

    <div>
      <p
        class="mb-4 text-sm font-bold uppercase tracking-widest text-majella-wood"
      >
        Pagine
      </p>
      <ul class="space-y-2 text-sm text-white/82">
        {
          navigation.map((item) => (
            <li>
              <a class="hover:text-white" href={item.href}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <p
        class="mb-4 text-sm font-bold uppercase tracking-widest text-majella-wood"
      >
        Riferimenti
      </p>
      <ul class="space-y-2 text-sm text-white/82">
        <li>
          <a class="hover:text-white" href={`mailto:${site.operativeEmail}`}
            >{site.operativeEmail}</a
          >
        </li>
        {
          footerLinks.map((item) => (
            <li>
              <a class="hover:text-white" href={item.href}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
  <div
    class="border-t border-white/12 px-4 py-5 text-center text-xs uppercase tracking-widest text-white/62"
  >
    © {year}
    {site.name}. Maiella, Abruzzo.
  </div>
</footer>
