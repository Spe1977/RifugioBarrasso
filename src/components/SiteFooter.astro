---
import { footerLinks, navigation, site } from "@data/site";

const year = new Date().getFullYear();
---

<footer class="terrain-surface text-white">
  <div
    class="mx-auto grid max-w-7xl gap-10 px-4 py-12 sm:px-6 lg:grid-cols-[1.4fr_1fr_1fr] lg:px-8"
  >
    <div>
      <picture>
        <source srcset="/assets/brand/logo.png" type="image/png" />
        <img
          src="/assets/brand/logo.png"
          alt="Logo del Rifugio Paolo Barrasso"
          class="mb-5 h-[54px] w-[54px] bg-white/95 object-contain"
          loading="lazy"
          width="54"
          height="54"
        />
      </picture>
      <p class="font-display text-2xl font-black uppercase tracking-wide">
        {site.name}
      </p>
      <p class="mt-3 max-w-md text-sm leading-6 text-white/78">
        {site.location}, {site.subtitle}. Gestione {site.manager}.
      </p>
    </div>

    <div>
      <p
        class="mb-4 text-sm font-bold uppercase tracking-widest text-majella-wood"
      >
        Pagine
      </p>
      <ul class="space-y-2 text-sm text-white/82">
        {
          navigation.map((item) => (
            <li>
              <a class="hover:text-white" href={item.href}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <p
        class="mb-4 text-sm font-bold uppercase tracking-widest text-majella-wood"
      >
        Riferimenti
      </p>
      <ul class="space-y-2 text-sm text-white/82">
        <li>
          <a class="hover:text-white" href={`mailto:${site.operativeEmail}`}
            >{site.operativeEmail}</a
          >
        </li>
        <li>
          <a class="hover:text-white" href={`mailto:${site.infoEmail}`}
            >{site.infoEmail}</a
          >
        </li>
        <li>
          <a
            class="inline-flex items-center gap-2 hover:text-white"
            href={site.facebookUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg
              aria-hidden="true"
              class="h-4 w-4 shrink-0"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path
                d="M22 12.06C22 6.51 17.52 2 12 2S2 6.51 2 12.06c0 5.02 3.66 9.18 8.44 9.94v-7.03H7.9v-2.91h2.54V9.85c0-2.52 1.49-3.91 3.77-3.91 1.09 0 2.23.2 2.23.2v2.46h-1.26c-1.24 0-1.63.78-1.63 1.57v1.89h2.78l-.44 2.91h-2.34V22C18.34 21.24 22 17.08 22 12.06Z"
              ></path>
            </svg>
            <span>Facebook</span>
          </a>
        </li>
        {
          footerLinks.map((item) => (
            <li>
              <a class="hover:text-white" href={item.href}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
  <div
    class="border-t border-white/12 px-4 py-5 text-center text-xs uppercase tracking-widest text-white/62"
  >
    © {year}
    {site.name}. Maiella, Abruzzo.
  </div>
</footer>
