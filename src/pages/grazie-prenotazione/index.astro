---
import PageHero from "@components/PageHero.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { site } from "@data/site";
---

<BaseLayout
  title={`Richiesta ricevuta | ${site.name}`}
  description="Pagina di conferma dopo l'invio della richiesta di prenotazione."
>
  <PageHero
    eyebrow="Richiesta ricevuta"
    title="Grazie"
    lead="La richiesta non è ancora una prenotazione confermata. Il gestore risponderà dopo la verifica della disponibilità."
  />
</BaseLayout>
