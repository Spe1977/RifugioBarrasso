---
import PageHero from "@components/PageHero.astro";
import SectionHeading from "@components/SectionHeading.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { pageMeta, rules } from "@data/content";
import { site } from "@data/site";
---

<BaseLayout title={pageMeta.info.title} description={pageMeta.info.description}>
  <PageHero
    eyebrow="Info e regole"
    title="Il patto del buon viandante"
    lead="Salire fino al Barrasso significa vivere la montagna in modo autentico, e lasciare il rifugio pulito, sicuro e accogliente è un dono per noi e per gli altri."
    leadClass="text-justify"
  />

  <section
    class="paper-surface py-20 [&_li]:text-justify [&_p]:text-justify [&_span.block]:text-justify"
  >
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div>
        <article
          class="mb-12 overflow-hidden rounded-3xl border border-majella-green/10 bg-white shadow-soft"
          aria-labelledby="come-raggiungere-rifugio"
        >
          <div class="grid gap-0">
            <div
              class="bg-majella-green p-7 text-majella-stone sm:p-9 lg:p-10"
              data-access-heading
            >
              <div
                class="mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-majella-wood text-3xl shadow-sm"
                aria-hidden="true"
              >
                🥾
              </div>
              <p
                class="mb-3 text-xs font-black uppercase tracking-[0.24em] text-majella-wood"
              >
                Accesso al rifugio
              </p>
              <h2
                id="come-raggiungere-rifugio"
                class="font-display text-2xl font-black uppercase leading-tight sm:text-3xl"
              >
                Come raggiungere il Rifugio
              </h2>
              <p
                class="mt-5 text-base font-medium leading-relaxed text-majella-stone/85"
              >
                Il percorso alterna strada comunale, tratti brecciati e sentiero
                escursionistico. Valuta sempre condizioni meteo, mezzo e
                attrezzatura.
              </p>
            </div>

            <div class="space-y-7 p-6 sm:p-8 lg:p-10">
              <div class="grid gap-4 sm:grid-cols-[3rem_1fr]">
                <div
                  class="flex h-12 w-12 items-center justify-center rounded-full bg-majella-lightgreen font-display text-lg font-black text-majella-green"
                  aria-hidden="true"
                >
                  1
                </div>
                <div>
                  <h3
                    class="font-display text-lg font-black leading-snug text-majella-green"
                  >
                    Da Caramanico Terme verso San Nicolao e Macere Piane
                  </h3>
                  <p class="mt-2 text-base leading-relaxed text-gray-700">
                    Raggiungi il paese di Caramanico Terme e segui le
                    indicazioni per la frazione di San Nicolao (circa 3 km).
                    Superato il piccolo abitato, prosegui in direzione della
                    località Macere Piane.
                  </p>
                </div>
              </div>

              <div class="grid gap-4 sm:grid-cols-[3rem_1fr]" data-access-steps>
                <div
                  class="flex h-12 w-12 items-center justify-center rounded-full bg-majella-lightgreen font-display text-lg font-black text-majella-green"
                  aria-hidden="true"
                >
                  2
                </div>
                <div>
                  <h3
                    class="font-display text-lg font-black leading-snug text-majella-green"
                  >
                    Da Macere Piane a Guado Sant'Antonio (1.220 m s.l.m.)
                  </h3>
                  <p class="mt-2 text-base leading-relaxed text-gray-700">
                    Una volta arrivato in località Macere Piane, troverai un
                    piccolo parcheggio brecciato. Da qui hai due opzioni per
                    raggiungere Guado Sant'Antonio:
                  </p>
                  <ul
                    class="mt-3 space-y-3 text-base leading-relaxed text-gray-700"
                  >
                    <li class="flex gap-3">
                      <span class="text-majella-wood" aria-hidden="true">•</span
                      >
                      <span>
                        <strong>A piedi (consigliato):</strong> lascia l'auto al parcheggio
                        e imbocca la strada comunale. È un percorso di circa 3 km
                        che richiede 1 ora di cammino.
                      </span>
                    </li>
                    <li class="flex gap-3">
                      <span class="text-majella-wood" aria-hidden="true">•</span
                      >
                      <span>
                        <strong>In auto:</strong> è possibile tentare di salire con
                        l'auto percorrendo la stessa strada comunale, ma
                        <strong> attenzione</strong>: il fondo stradale è molto
                        rovinato, quindi valuta bene il mezzo a disposizione.
                      </span>
                    </li>
                  </ul>
                </div>
              </div>

              <div class="grid gap-4 sm:grid-cols-[3rem_1fr]">
                <div
                  class="flex h-12 w-12 items-center justify-center rounded-full bg-majella-lightgreen font-display text-lg font-black text-majella-green"
                  aria-hidden="true"
                >
                  3
                </div>
                <div>
                  <h3
                    class="font-display text-lg font-black leading-snug text-majella-green"
                  >
                    L'ultimo tratto: il Sentiero B3
                  </h3>
                  <p class="mt-2 text-base leading-relaxed text-gray-700">
                    Una volta arrivato a Guado Sant'Antonio, prendi il
                    <strong> sentiero B3</strong>. In circa un'ora di cammino
                    arriverai a destinazione al Rifugio.
                  </p>
                </div>
              </div>

              <a
                href="https://www.google.com/maps/search/?api=1&query=42.13584,14.06078"
                target="_blank"
                rel="noreferrer"
                class="mx-auto flex w-[85%] items-center justify-center rounded-2xl bg-majella-green px-4 py-4 text-center font-display text-base font-black uppercase tracking-[0.04em] text-white shadow-sm transition-colors hover:bg-majella-wood-dark focus-visible:outline-majella-red sm:w-fit"
                aria-label="Naviga verso il Rifugio Paolo Barrasso su Google Maps"
              >
                Naviga verso il Rifugio
              </a>
            </div>
          </div>
        </article>

        <article
          class="mb-8 overflow-hidden rounded-[2rem] bg-majella-green text-majella-stone shadow-soft ring-1 ring-majella-green/20"
          aria-labelledby="cosa-trovi-barrasso"
        >
          <div class="p-6 sm:p-8">
            <div class="flex flex-col gap-5 sm:flex-row sm:items-center">
              <div
                class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-majella-wood text-4xl shadow-sm"
                aria-hidden="true"
              >
                🏡
              </div>
              <div>
                <p
                  class="mb-2 text-xs font-black uppercase tracking-[0.24em] text-majella-wood"
                >
                  Dotazioni del rifugio
                </p>
                <h2
                  id="cosa-trovi-barrasso"
                  class="font-display text-2xl font-black uppercase leading-tight text-majella-stone sm:text-3xl"
                >
                  COSA TROVI ALL'INTERNO DEL BARRASSO
                </h2>
              </div>
            </div>

            <div
              class="mt-7 grid gap-7 border-t border-majella-stone/20 pt-7 lg:grid-cols-[1.15fr_0.85fr]"
            >
              <div>
                <h3
                  class="text-base font-black uppercase leading-relaxed text-majella-stone"
                >
                  NEL LOCALE CHIUSO (ACCESSIBILE SOLO SU <a
                    href="/prenotazioni/"
                    class="text-majella-stone underline decoration-majella-wood underline-offset-4 transition-colors hover:text-majella-wood"
                    >PRENOTAZIONE</a
                  >) TROVI
                </h3>
                <ul
                  class="mt-3 space-y-2 text-base font-medium leading-relaxed text-majella-stone/90"
                >
                  <li class="flex gap-3">
                    <span class="text-majella-wood" aria-hidden="true">•</span>
                    <span>un tavolo con panche;</span>
                  </li>
                  <li class="flex gap-3">
                    <span class="text-majella-wood" aria-hidden="true">•</span>
                    <span>un fornello con bombola a gas;</span>
                  </li>
                  <li class="flex gap-3">
                    <span class="text-majella-wood" aria-hidden="true">•</span>
                    <span
                      >un armadietto da mantenere sempre chiuso contenente
                      attrezzatura da cucina;</span
                    >
                  </li>
                  <li class="flex gap-3">
                    <span class="text-majella-wood" aria-hidden="true">•</span>
                    <span>legna per il camino;</span>
                  </li>
                  <li class="flex gap-3">
                    <span class="text-majella-wood" aria-hidden="true">•</span>
                    <span
                      >un soppalco con tavolato utilizzabile come zona notte.</span
                    >
                  </li>
                </ul>
                <p
                  class="mt-5 rounded-2xl bg-majella-stone px-4 py-3 text-base font-bold leading-relaxed text-majella-green"
                >
                  Per il pernottamento è necessario portare con sé sacco a pelo
                  e stuoino/materassino.
                </p>
              </div>

              <div
                class="border-t border-majella-stone/20 pt-7 lg:border-t-0 lg:pt-0"
              >
                <h3
                  class="text-base font-black uppercase leading-relaxed text-majella-stone"
                >
                  NEL LOCALE APERTO (SEMPRE LIBERAMENTE ACCESSIBILE) TROVI
                </h3>
                <ul
                  class="mt-3 space-y-2 text-base font-medium leading-relaxed text-majella-stone/90"
                >
                  <li class="flex gap-3">
                    <span class="text-majella-wood" aria-hidden="true">•</span>
                    <span>un tavolo con panche;</span>
                  </li>
                  <li class="flex gap-3">
                    <span class="text-majella-wood" aria-hidden="true">•</span>
                    <span>il camino;</span>
                  </li>
                  <li class="flex gap-3">
                    <span class="text-majella-wood" aria-hidden="true">•</span>
                    <span>una stufa;</span>
                  </li>
                  <li class="flex gap-3">
                    <span class="text-majella-wood" aria-hidden="true">•</span>
                    <span>legna da ardere.</span>
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </article>

        <ul class="space-y-6 text-majella-darkstone font-medium">
          <li
            class="flex items-start rounded-2xl border border-red-100 bg-red-50 p-5"
          >
            <div
              class="mr-4 mt-1 shrink-0 rounded-full bg-white p-3 shadow-sm flex items-center justify-center w-12 h-12"
            >
              <span class="text-2xl" aria-hidden="true">🐾</span>
            </div>
            <div>
              <strong class="mb-1 block text-lg uppercase text-majella-red"
                >I nostri Amici a 4 Zampe</strong
              >
              <span class="block text-base leading-relaxed text-gray-700"
                >Sappiamo quanto sia bello camminare con il proprio cane, ma il
                rifugio si trova nel cuore della <strong
                  >Zona A (Riserva Integrale)</strong
                > del Parco Nazionale. Per tutelare la delicatissima fauna selvatica
                che vive in queste aree (come lupi, cmosci e cervi),
                <strong>è assolutamente vietato l'accesso ai cani</strong>.
                Confidiamo nella tua comprensione per proteggere questo fragile
                ecosistema.</span
              >
            </div>
          </li>

          <li
            class="flex items-start rounded-2xl border border-blue-100 bg-blue-50 p-5"
          >
            <div
              class="mr-4 mt-1 shrink-0 rounded-full bg-blue-50 p-3 shadow-sm flex items-center justify-center w-12 h-12"
            >
              <span class="text-2xl" aria-hidden="true">💧</span>
            </div>
            <div>
              <strong class="mb-1 block text-lg text-majella-green"
                >Acqua e Servizi</strong
              >
              <span class="block text-base leading-relaxed text-gray-600"
                >Lassù si vive con l'essenziale. Ricordati che all'interno e
                all'esterno della struttura <strong
                  >non ci sono servizi igienici e non c'è acqua potabile</strong
                >. Fai scorta di abbondante acqua a valle prima di iniziare la
                salita!</span
              >
            </div>
          </li>

          <li
            class="flex items-start rounded-2xl border border-gray-200 bg-gray-50 p-5"
          >
            <div
              class="mr-4 mt-1 shrink-0 rounded-full bg-gray-100 p-3 shadow-sm flex items-center justify-center w-12 h-12"
            >
              <span class="text-2xl" aria-hidden="true">🎒</span>
            </div>
            <div>
              <strong class="mb-1 block text-lg text-majella-green"
                >La Regola dello Zaino</strong
              >
              <span class="block text-base leading-relaxed text-gray-600"
                >Tutto ciò che sale, deve scendere. Riporta a valle i tuoi
                rifiuti (e se porti via anche quelli scordati da altri, la
                montagna ti ringrazierà!). <strong
                  >Non lasciare cibo aperto.</strong
                > Puoi donare solo alimenti integri e sigillati (es. in latta) per
                le emergenze.</span
              >
            </div>
          </li>

          <li
            class="flex items-start rounded-2xl border border-orange-100 bg-orange-50 p-5"
          >
            <div
              class="mr-4 mt-1 shrink-0 rounded-full bg-orange-50 p-3 shadow-sm flex items-center justify-center w-12 h-12"
            >
              <span class="text-2xl" aria-hidden="true">🔥</span>
            </div>
            <div>
              <strong class="mb-1 block text-lg text-majella-green"
                >Il Calore del Bivacco</strong
              >
              <span class="block text-base leading-relaxed text-gray-600"
                >Usa il camino con cura. Prima di partire, prepara un po' di
                legna secca per chi arriverà infreddolito dopo di te. Un
                dettaglio vitale: <strong
                  >è severamente vietato svuotare la cenere all'esterno</strong
                >, per prevenire incendi.</span
              >
            </div>
          </li>

          <li
            class="flex items-start rounded-2xl border border-majella-green/15 bg-majella-stone p-5"
          >
            <div
              class="mr-4 mt-1 shrink-0 rounded-full border border-gray-200 bg-white p-3 shadow-sm flex items-center justify-center w-12 h-12"
            >
              <span class="text-2xl" aria-hidden="true">🚪</span>
            </div>
            <div>
              <strong class="mb-1 block text-lg text-majella-green"
                >Gli Ultimi Gesti</strong
              >
              <span class="block text-base leading-relaxed text-gray-600"
                >Prima di salutare il Barrasso, verifica di aver chiuso
                saldamente finestre e mandate. Questo semplice gesto impedisce
                alle bufere e agli animali selvatici di entrare e danneggiare il
                rifugio.</span
              >
            </div>
          </li>
        </ul>

        <div class="mt-16 grid gap-6 md:grid-cols-2">
          <div
            class="rounded-3xl border border-majella-green/15 bg-white p-8 shadow-sm sm:p-10"
          >
            <p
              class="mb-2 text-sm font-black uppercase tracking-widest text-majella-red"
            >
              Gestione
            </p>
            <p
              class="font-display text-xl font-bold text-majella-green sm:text-2xl"
            >
              {site.manager}
            </p>
          </div>

          <div
            class="rounded-3xl border border-majella-green/15 bg-white p-8 shadow-sm sm:p-10"
          >
            <p
              class="mb-2 text-sm font-black uppercase tracking-widest text-majella-red"
            >
              Contatto operativo
            </p>
            <div class="space-y-3">
              <a
                href={`mailto:${site.operativeEmail}`}
                class="block break-all font-display text-base font-bold text-majella-darkstone underline transition-colors hover:text-majella-red sm:text-lg lg:text-xl"
                >{site.operativeEmail}</a
              >
              <a
                href={`mailto:${site.infoEmail}`}
                class="block break-all font-display text-base font-bold text-majella-darkstone underline transition-colors hover:text-majella-red sm:text-lg lg:text-xl"
                >{site.infoEmail}</a
              >
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-20 [&_li]:text-justify">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <SectionHeading eyebrow="Utilizzo" title="Regolamento Tecnico" />
      <ul class="grid gap-3 md:grid-cols-2">
        {
          rules.map((rule) => (
            <li class="border-l-4 border-majella-green/20 bg-majella-stone px-5 py-4 leading-7 text-base font-medium text-majella-darkstone">
              {rule}
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>
